{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DiagramSpec",
  "type": "object",
  "required": ["specVersion", "width", "height", "primitives"],
  "additionalProperties": false,
  "properties": {
    "specVersion": { "type": "integer", "enum": [1] },
    "width": { "type": "integer", "minimum": 200, "maximum": 1600 },
    "height": { "type": "integer", "minimum": 200, "maximum": 1200 },
    "background": { "type": "string" },
    "title": { "type": "string", "maxLength": 120 },
    "primitives": {
      "type": "array",
      "minItems": 1,
      "maxItems": 200,
      "items": {
        "type": "object",
        "required": ["type"],
        "additionalProperties": true,
        "properties": {
          "type": {
            "type": "string",
            "enum": ["line", "polygon", "circle", "text", "rect"]
          }
        }
      }
    }
  }
}
