<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>DiagGen</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="container">
      <h1>AI Diagram Generator</h1>
      <p>Describe a diagram and generate a preview + API artifacts.</p>

      <% if (typeof error === "string" && error) { %>
      <div class="error"><%= error %></div>
      <% } %>

      <form action="/generate" method="post" class="form">
        <label for="prompt">Diagram prompt</label>
        <textarea id="prompt" name="prompt" rows="5" placeholder="Example: a triangle demonstrating pythagoras theorem" required></textarea>

        <label for="provider">Provider</label>
        <select id="provider" name="provider">
          <option value="mock" <%= defaultProvider === "mock" ? "selected" : "" %>>mock</option>
          <option value="openai" <%= defaultProvider === "openai" ? "selected" : "" %>>openai (stub)</option>
          <option value="anthropic" <%= defaultProvider === "anthropic" ? "selected" : "" %>>anthropic (stub)</option>
        </select>

        <button type="submit">Generate</button>
      </form>

      <p><a href="/diagrams">View history</a></p>
    </main>
  </body>
</html>
