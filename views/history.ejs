<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>History - DiagGen</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="container">
      <h1>Diagram history</h1>
      <p><a href="/">Create new diagram</a></p>

      <% if (!history.length) { %>
      <p>No diagrams yet.</p>
      <% } %>

      <ul class="history-list">
        <% history.forEach(function(item) { %>
        <li>
          <a href="/diagrams/<%= item.id %>"><%= item.prompt %></a>
          <span class="meta">(<%= item.status %>, <%= item.provider || "n/a" %>)</span>
        </li>
        <% }) %>
      </ul>
    </main>
  </body>
</html>
