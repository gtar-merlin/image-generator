<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>Diagram <%= diagram.request.id %></title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="container">
      <h1>Diagram result</h1>
      <p><a href="/">Create new</a> | <a href="/diagrams">History</a></p>
      <p><strong>Prompt:</strong> <%= diagram.request.originalPrompt %></p>
      <p><strong>Status:</strong> <%= diagram.request.status %></p>
      <p><strong>Provider:</strong> <%= diagram.generation.provider %></p>

      <section class="preview">
        <h2>SVG preview</h2>
        <div class="svg-box"><%- svg %></div>
        <p>
          <a href="/api/diagrams/<%= diagram.request.id %>/image" target="_blank">Open image endpoint</a>
        </p>
      </section>

      <section>
        <h2>Stored compiled JS</h2>
        <pre><code><%= compiledJs %></code></pre>
      </section>

      <section>
        <h2>Stored DiagramSpec</h2>
        <pre><code><%= specJson %></code></pre>
      </section>
    </main>
  </body>
</html>
